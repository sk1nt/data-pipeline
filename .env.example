# Example environment file for local development
# Copy this to `.env` and fill in secrets before running.

# Discord bot token
DISCORD_BOT_TOKEN=changeme

# Discord user ID to receive automated alert DMs (critical errors, ML trades, etc.)
DISCORD_ALERT_DM_USER_ID=704125082750156840

# Redis pub/sub channel that services publish critical errors to (consumed by Discord bot)
ERROR_ALERT_CHANNEL=errors:critical:stream

# Tastytrade sandbox/live toggles and tokens
TASTYTRADE_USE_SANDBOX=true
TASTYTRADE_DRY_RUN=true
TASTYTRADE_CLIENT_ID=
TASTYTRADE_CLIENT_SECRET=
TASTYTRADE_REFRESH_TOKEN=
# TastyTrade DXLink market data. TRIN indicators use dxFeed TimeAndSale events.
TASTYTRADE_STREAM_SYMBOLS=MES,MNQ,NQ,SPY,QQQ,VIX,$TRIN,$TRINSP,$TRINND,$TRIN/Q

# Admin API key (used to protect admin endpoints)
ADMIN_API_KEY=changeme

# Redis & DB
REDIS_URL=redis://localhost:6379
DATABASE_URL=data/gex_data.db

# ==========================================================================
# Sweep runner (trading machine — WSL only)
# ==========================================================================

# Sierra Chart data directory (WSL maps C:\ to /mnt/c/)
SC_DATA_DIR=/mnt/c/SierraChart/Data
# Override individual file paths only if SC writes them elsewhere:
# SC_DOM_SNAPSHOT_PATH=/mnt/c/SierraChart/Data/dom_snapshot.json
# SC_TRADE_FLOW_PATH=/mnt/c/SierraChart/Data/trade_flow.json
# SC_DANGER_TRIGGER_PATH=/mnt/c/SierraChart/Data/danger_trigger.json

# Symbol
SC_DOM_SYMBOL=MNQ

# Position file written by a second ACSIL study; leave blank to use SC_POSITION_OVERRIDE
SC_POSITIONS_PATH=/mnt/c/SierraChart/Data/position_snapshot.json
# For testing only — set to integer (e.g. 2 = long 2 contracts, -1 = short 1)
SC_POSITION_OVERRIDE=

# DTC Protocol Server (Sierra Chart -> Global Settings -> DTC Protocol Server)
# SC_DTC_HOST defaults to the WSL2 Windows host (auto-detected from /etc/resolv.conf)
# Override if your SC machine is not the WSL host (e.g. a separate LAN machine)
SC_DTC_HOST=
SC_DTC_PORT=11099
# Full Sierra Chart symbol — update each roll (e.g. MNQU26_FUT_CME in June)
SC_DTC_SYMBOL=MNQM26_FUT_CME

# ---------------------------------------------------------------------------
# Sierra Chart Discord DM trading  (sc_trade_listener.py on trading computer)
# ---------------------------------------------------------------------------
# Trade account name in SC (Simulation or live account)
SC_TRADE_ACCOUNT=Sim1
# Redis host reachable from the trading computer (Windows)
# sc_trade_listener.py defaults to 192.168.168.151 if not set here
# REDIS_HOST=192.168.168.151
# Redis channels for signal/ack bus
SC_TRADE_SIGNAL_CHANNEL=sc:trade:signal
SC_TRADE_ACK_CHANNEL=sc:trade:ack
# Dry-run default for !sc context (true = signals publish, SC ignores; false = live)
SC_TRADE_DRY_RUN=true

# Bridge polling
SC_BRIDGE_POLL_MS=100
SC_BRIDGE_STALE_MS=2000

# SAFETY: keep false until system is fully validated in dry-run
# Set true to arm live FlattenAndCancelAllOrders() via SC danger trigger
SWEEP_LIVE_MODE=false

# Stop/exit signal thresholds (MNQ ticks; 1 tick = 0.25 pts = $0.50/contract)
SWEEP_TRIGGER_TICKS=10
SWEEP_TRIGGER_WINDOW_SECONDS=30
SWEEP_COOLDOWN_SECONDS=60
SWEEP_WARNING_TICKS=15
SWEEP_DANGER_TICKS=25
SWEEP_CRITICAL_TICKS=35
SWEEP_WARNING_CONFIDENCE=0.65
SWEEP_DANGER_CONFIDENCE=0.78
SWEEP_CRITICAL_CONFIDENCE=0.85
SWEEP_LEVEL2_ACKNOWLEDGE_SECONDS=10

# DuckDB training data accumulation
SWEEP_DB_PATH=data/fast_moves.db

# ML model path (auto-loaded by sweep_classifier_service if present)
SWEEP_MODEL_PATH=src/ml/sweep_model.pkl
# Min training samples before a new model is saved
SWEEP_MIN_TRAIN_SAMPLES=200

# GEXBot Chromium session (cookies/profile stay under ignored data/runtime/)
GEX_PLAYWRIGHT_URL=
GEX_PLAYWRIGHT_LOGIN_URL=
GEX_PLAYWRIGHT_BUTTON=
GEX_PLAYWRIGHT_SUCCESS=
GEX_PLAYWRIGHT_PROFILE=data/runtime/playwright/gexbot
GEX_PLAYWRIGHT_WAIT_SECONDS=5
