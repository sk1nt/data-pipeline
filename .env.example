# Example environment file for local development
# Copy this to `.env` and fill in secrets before running.

# Discord bot token
DISCORD_BOT_TOKEN=changeme

# Tastytrade sandbox/live toggles and tokens
TASTYTRADE_USE_SANDBOX=true
TASTYTRADE_DRY_RUN=true
TASTYTRADE_CLIENT_ID=
TASTYTRADE_CLIENT_SECRET=
TASTYTRADE_REFRESH_TOKEN=

# Admin API key (used to protect admin endpoints)
ADMIN_API_KEY=changeme

# Redis & DB
REDIS_URL=redis://localhost:6379
DATABASE_URL=data/gex_data.db

# ==========================================================================
# Sweep / Sierra Chart — MOVED to data-trading (trading machine)
# https://github.com/sk1nt/data-trading — copy .env.example there.
# This server only publishes gex:snapshot:stream and serves parquet paths.
# ==========================================================================
# DATA_TRADING_ROOT=~/projects/data-trading
